+        // Detect inline image data URI emitted by the screenshot tool and
+        // convert to a multimodal content array instead of a plain text blob.
+        let tool_content = if let Some(img_start) = result.find("\ndata:image/") {
+            let text_part = result[..img_start].to_string();
+            let data_uri = &result[img_start + 1..]; // strip leading '\n'
