+                if !text_part.trim().is_empty() {
+                    blocks.push(serde_json::json!({"type": "text", "text": text_part}));
+                }
+                if let Ok(img_val) = serde_json::to_value(&img_block) {
+                    blocks.push(img_val);
+                }
+                serde_json::Value::Array(blocks)
+            } else {
+                serde_json::Value::String(result)
+            }
+        } else {
+            serde_json::Value::String(result)
+        };
